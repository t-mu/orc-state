{
  "name": "@t-mu/orc-state",
  "version": "0.1.0",
  "description": "Spawn, claim and fall in line. Agnostic cross-provider compatible agentic framework backed by nothing but files and empty promises.",
  "type": "module",
  "license": "MIT",
  "bin": {
    "orc": "./cli/orc.ts"
  },
  "exports": {
    ".": "./index.ts",
    "./adapters": "./adapters/index.ts",
    "./coordinator": "./coordinator.ts",
    "./schemas/*": "./schemas/*.json"
  },
  "files": [
    "adapters",
    "cli",
    "index.mjs",
    "lib",
    "mcp",
    "schemas",
    "skills",
    "templates",
    "coordinator.mjs",
    "contracts.md",
    "README.md"
  ],
  "scripts": {
    "typecheck": "tsc --project tsconfig.check.json --noEmit",
    "lint": "eslint . --ignore-pattern '**/*.test.ts' --ignore-pattern '**/*.e2e.test.ts' --ignore-pattern 'eslint.config.mjs'",
    "lint:fix": "eslint . --fix --ignore-pattern '**/*.test.ts' --ignore-pattern '**/*.e2e.test.ts' --ignore-pattern 'eslint.config.mjs'",
    "prepare": "simple-git-hooks",
    "pretest": "tsc --project tsconfig.check.json --noEmit && eslint . --ignore-pattern '**/*.test.ts' --ignore-pattern '**/*.e2e.test.ts' --ignore-pattern 'eslint.config.mjs'",
    "test": "vitest run",
    "test:e2e": "vitest run --config vitest.e2e.config.mjs",
    "pack:dry": "npm pack --dry-run"
  },
  "simple-git-hooks": {
    "pre-commit": "lint-staged"
  },
  "lint-staged": {
    "*.{ts,mts,cts}": "eslint --fix --ignore-pattern '**/*.test.ts' --ignore-pattern '**/*.e2e.test.ts' --ignore-pattern 'eslint.config.mjs'"
  },
  "engines": {
    "node": ">=24"
  },
  "dependencies": {
    "@inquirer/prompts": "7.5.2",
    "@modelcontextprotocol/sdk": "1.27.1",
    "ajv": "8.18.0",
    "node-pty": "1.1.0"
  },
  "devDependencies": {
    "@types/node": "25.5.0",
    "eslint": "10.0.3",
    "lint-staged": "16.3.3",
    "simple-git-hooks": "2.13.1",
    "typescript": "5.9.3",
    "typescript-eslint": "8.57.0",
    "vitest": "4.0.18"
  }
}
