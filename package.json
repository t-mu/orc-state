{
  "name": "orc-state",
  "version": "0.1.0",
  "description": "Spawn, claim and fall in line. Agnostic cross-provider compatible agentic framework backed by nothing but files and empty promises.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/t-mu/orc-state.git"
  },
  "homepage": "https://github.com/t-mu/orc-state",
  "bugs": "https://github.com/t-mu/orc-state/issues",
  "keywords": [
    "orchestration",
    "multi-agent",
    "coding-agent",
    "autonomous",
    "provider-agnostic",
    "cli"
  ],
  "bin": {
    "orc": "./dist/cli/orc.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./adapters": {
      "types": "./dist/adapters/index.d.ts",
      "default": "./dist/adapters/index.js"
    },
    "./coordinator": {
      "types": "./dist/coordinator.d.ts",
      "default": "./dist/coordinator.js"
    },
    "./lib/stateValidation": {
      "types": "./dist/lib/stateValidation.d.ts",
      "default": "./dist/lib/stateValidation.js"
    },
    "./lib/eventValidation": {
      "types": "./dist/lib/eventValidation.d.ts",
      "default": "./dist/lib/eventValidation.js"
    },
    "./schemas/*": "./dist/schemas/*.json"
  },
  "files": [
    "dist",
    "docs",
    "README.md"
  ],
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "node scripts/build.ts",
    "build:types": "tsc --project tsconfig.build.json",
    "typecheck": "tsc --project tsconfig.check.json --noEmit",
    "typecheck:test": "tsc --project tsconfig.test.json --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "codex": "codex --dangerously-bypass-approvals-and-sandbox",
    "link-local-agents": "bash scripts/link-local-agents.sh",
    "link-local-all": "bash scripts/link-local-skills.sh && bash scripts/link-local-agents.sh",
    "link-local-skills": "bash scripts/link-local-skills.sh",
    "prepare": "node scripts/prepare.ts",
    "prepublishOnly": "npm run build && npm test",
    "pretest": "tsc --project tsconfig.check.json --noEmit && tsc --project tsconfig.test.json --noEmit && eslint .",
    "test": "vitest run",
    "test:e2e": "vitest run --config vitest.e2e.config.mjs",
    "pack:dry": "npm pack --dry-run",
    "task:done": "node cli/task-mark-done.ts"
  },
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged"
  },
  "lint-staged": {
    "*.{ts,tsx,mts,cts}": "eslint --fix"
  },
  "engines": {
    "node": ">=24"
  },
  "dependencies": {
    "@inquirer/prompts": "7.5.2",
    "@modelcontextprotocol/sdk": "1.27.1",
    "ajv": "8.18.0",
    "better-sqlite3": "12.8.0",
    "chalk": "5.4.1",
    "figlet": "1.8.0",
    "ink": "5.2.1",
    "node-pty": "1.1.0",
    "react": "18.3.1",
    "tsx": "4.19.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "7.6.13",
    "@types/figlet": "1.7.0",
    "@types/node": "25.5.0",
    "@types/react": "18.3.21",
    "esbuild": "0.25.4",
    "eslint": "10.0.3",
    "ink-testing-library": "4.0.0",
    "lint-staged": "16.3.3",
    "simple-git-hooks": "2.13.1",
    "typescript": "5.9.3",
    "typescript-eslint": "8.57.0",
    "vitest": "4.0.18"
  }
}
