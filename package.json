{
  "name": "@t-mu/orc-state",
  "version": "0.1.0",
  "description": "Spawn, claim and fall in line. Agnostic cross-provider compatible agentic framework backed by nothing but files and empty promises.",
  "type": "module",
  "license": "MIT",
  "bin": {
    "orc": "./cli/orc.ts"
  },
  "exports": {
    ".": "./index.ts",
    "./adapters": "./adapters/index.ts",
    "./coordinator": "./coordinator.ts",
    "./lib/stateValidation": "./lib/stateValidation.ts",
    "./lib/eventValidation": "./lib/eventValidation.ts",
    "./schemas/*": "./schemas/*.json"
  },
  "files": [
    "adapters",
    "assets",
    "cli",
    "coordinator.ts",
    "index.ts",
    "lib",
    "mcp",
    "schemas",
    "types",
    "skills",
    "templates",
    "contracts.md",
    "README.md"
  ],
  "types": "./index.ts",
  "scripts": {
    "typecheck": "tsc --project tsconfig.check.json --noEmit",
    "typecheck:test": "tsc --project tsconfig.test.json --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prepare": "simple-git-hooks && chmod +x node_modules/node-pty/prebuilds/darwin-arm64/spawn-helper 2>/dev/null || true",
    "pretest": "tsc --project tsconfig.check.json --noEmit && tsc --project tsconfig.test.json --noEmit && eslint .",
    "test": "vitest run",
    "test:e2e": "vitest run --config vitest.e2e.config.mjs",
    "pack:dry": "npm pack --dry-run",
    "task:done": "node --experimental-strip-types cli/task-mark-done.ts"
  },
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged"
  },
  "lint-staged": {
    "*.{ts,tsx,mts,cts}": "eslint --fix"
  },
  "engines": {
    "node": ">=24"
  },
  "dependencies": {
    "@inquirer/prompts": "7.5.2",
    "@modelcontextprotocol/sdk": "1.27.1",
    "ajv": "8.18.0",
    "better-sqlite3": "12.8.0",
    "boxen": "8.0.1",
    "chalk": "5.4.1",
    "figlet": "1.8.0",
    "ink": "5.2.1",
    "ink-spinner": "5.0.0",
    "node-pty": "1.1.0",
    "react": "18.3.1",
    "terminal-image": "3.0.0",
    "tsx": "4.19.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "7.6.13",
    "@types/figlet": "1.7.0",
    "@types/node": "25.5.0",
    "@types/react": "18.3.21",
    "eslint": "10.0.3",
    "ink-testing-library": "4.0.0",
    "lint-staged": "16.3.3",
    "simple-git-hooks": "2.13.1",
    "typescript": "5.9.3",
    "typescript-eslint": "8.57.0",
    "vitest": "4.0.18"
  }
}
