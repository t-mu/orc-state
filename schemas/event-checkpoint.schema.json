{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "schemas/event-checkpoint.schema.json",
  "title": "Event Processing Checkpoint",
  "type": "object",
  "required": ["version", "last_processed_seq", "processed_event_ids", "updated_at"],
  "additionalProperties": false,
  "properties": {
    "version": {
      "type": "string",
      "const": "1"
    },
    "last_processed_seq": {
      "type": "integer",
      "minimum": 0
    },
    "processed_event_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
